{
  "name": "codex-dream-skin-desktop",
  "version": "1.1.2",
  "private": true,
  "description": "Cross-platform desktop control panel for Codex Dream Skin.",
  "author": "LiamTaan",
  "homepage": "https://github.com/LiamTaan/codex-dream",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check runtime-utils.js && node --check renderer/app.js && node --test tests/*.test.js",
    "dist:mac": "electron-builder --mac zip dmg --x64 --arm64",
    "dist:win": "electron-builder --win nsis zip"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "afterPack": "./scripts/sign-macos-app.cjs",
    "appId": "com.liamtaan.codexdreamskin",
    "productName": "Codex Dream Skin",
    "icon": "assets/icon.png",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "runtime-utils.js",
      "renderer/**",
      "assets/icon.png"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "skin",
        "filter": [
          "macos/**",
          "windows/**",
          "LICENSE",
          "README.md",
          "THIRD_PARTY_NOTICES.md"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "zip",
        "dmg"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "lucide": "^0.468.0"
  }
}
